{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for the read-only ODW shell: spawn the odw sidecar and show native notifications. No run-control surface.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-set-badge-count",
    "core:event:allow-emit",
    "shell:allow-spawn",
    {
      "identifier": "shell:allow-spawn",
      "allow": [{ "name": "binaries/odw", "sidecar": true, "args": ["serve", "--port", { "validator": "\\d+" }] }]
    },
    "notification:default",
    "notification:allow-notify"
  ]
}
